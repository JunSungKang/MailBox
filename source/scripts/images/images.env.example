REGISTRY=ghcr.io
IMAGE_NAMESPACE=junsungkang
VERSION=v1.0.0
IMAGE_NAME_PREFIX=mail-server-

# GitHub Container Registry login.
# GITHUB_USERNAME=JunSungKang
# GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GHCR_TOKEN can be used instead of GIT_TOKEN.

# Optional explicit image overrides.
# MAIL_SMTP_RECEIVER_IMAGE=ghcr.io/junsungkang/mail-server-smtp-receiver:v1.0.0
# MAIL_IMAP_MAILBOX_IMAGE=ghcr.io/junsungkang/mail-server-imap-mailbox:v1.0.0
# MAIL_WEBMAIL_UI_IMAGE=ghcr.io/junsungkang/mail-server-webmail-ui:v1.0.0
